---
layout: default
---

<div class="homepage">
  {# Hero starts #}
  <header class="hero bg-core-bg">
    <div class="wrapper">
      <div class="hero__columns switcher">
        <div>
          <span aria-hidden="true" class="hero__eyebrow">{{ intro.eyebrow }}</span>
          <div class="hero__content flow">
            <h1 class="hero__title">{{ intro.title }}</h1>
            {{ intro.summary | md | safe }}
            <a class="button" data-type="primary" href="{{ intro.buttonUrl }}">{{ intro.buttonText }}</a>
          </div>
        </div>
      </div>
    </div>
  </header>
  {# Hero ends #}

  {# Program overview start #}
  <div class="homepage__section bg-mid-bg">
    <div class="wrapper">
      <div class="headline all-center flow">
        <h2 class="headline__title">{{ overview.title }}</h2>
        <p>{{ overview.summary }}</p>
        <a class="button gap-top-size-1" data-type="primary" href="{{ overview.buttonUrl }}">{{ overview.buttonText }}</a>
      </div>
    </div>
  </div>
  {# Program overview end #}

  {# Lesson calendar start #}
  {% include "partials/lesson-calendar.njk" %}
  {# Lesson calendar end #}
</div>
